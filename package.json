{
  "name": "desktop-pet",
  "version": "1.0.0",
  "description": "🐱 一个可爱的桌面宠物小助手 | A cute desktop pet built with Electron",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --win --mac --linux",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "keywords": [
    "desktop-pet",
    "electron",
    "mascot",
    "kawaii",
    "cat",
    "widget",
    "windows",
    "macos",
    "linux"
  ],
  "author": "Joey",
  "license": "MIT",
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "25.1.8"
  },
  "build": {
    "appId": "com.joey.desktop-pet",
    "productName": "DesktopPet",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "style.css",
      "pet.js",
      "assets/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/tray-icon.png",
      "artifactName": "DesktopPet-${version}-Windows-${arch}.${ext}"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        }
      ],
      "icon": "assets/tray-icon.png",
      "artifactName": "DesktopPet-${version}-macOS-${arch}.${ext}",
      "category": "public.app-category.entertainment"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64"]
        },
        {
          "target": "deb",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/tray-icon.png",
      "artifactName": "DesktopPet-${version}-Linux-${arch}.${ext}",
      "category": "Utility"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "artifactName": "DesktopPet-${version}-Windows-Setup.${ext}"
    }
  }
}
